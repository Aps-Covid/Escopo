<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="750.0" prefWidth="1250.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.login.TelaGraficosController">
    <!-- Gráfico de Pizza -->
    <PieChart fx:id="pieChart" layoutX="63.0" layoutY="427.0" prefHeight="220.0" prefWidth="243.0" />

    <!-- Botão para atualizar os dados -->
    <Button fx:id="btnAtualizar" layoutX="464.0" layoutY="667.0" onAction="#atualizarDados" prefHeight="40.0" prefWidth="200.0" text="Atualizar Dados" />

    <!-- Label para status ou mensagem -->
    <Label fx:id="lblStatus" layoutX="20.0" layoutY="350.0" prefHeight="20.0" prefWidth="200.0" text="Status do gráfico" />
   <AreaChart layoutX="863.0" layoutY="426.0" prefHeight="200.0" prefWidth="302.0">
     <xAxis>
       <CategoryAxis side="BOTTOM" />
     </xAxis>
     <yAxis>
       <NumberAxis side="LEFT" />
     </yAxis>
   </AreaChart>
</AnchorPane>
