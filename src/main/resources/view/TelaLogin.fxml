<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="425.0" prefWidth="474.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.login.TelaLoginController">
    <children>
        <Button fx:id="btnClick" layoutX="88.0" layoutY="294.0" mnemonicParsing="false" onAction="#handleLoginButton" prefHeight="51.0" prefWidth="135.0" text="Entrar">
            <font>
                <Font size="19.0" />
            </font>
        </Button>
        <Label fx:id="lblMensagem" layoutX="202.0" layoutY="73.0" prefHeight="17.0" prefWidth="195.0" textAlignment="CENTER">
            <font>
                <Font size="18.0" />
            </font>
        </Label>
        <PasswordField fx:id="passwordField" layoutX="88.0" layoutY="194.0" prefHeight="51.0" prefWidth="297.0" promptText="Senha" />
        <TextField fx:id="usernameField" layoutX="88.0" layoutY="79.0" prefHeight="51.0" prefWidth="295.0" promptText="Login" />
        <Button fx:id="btnCadastro" layoutX="250.0" layoutY="294.0" mnemonicParsing="false" onAction="#abrirTelaCadastro" prefHeight="51.0" prefWidth="135.0" text="Cadastre-se">
            <font>
                <Font size="19.0" />
            </font>
        </Button>
    </children>
</AnchorPane>